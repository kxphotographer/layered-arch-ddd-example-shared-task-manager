{
	"private": true,
	"name": "@kxphotographer/layered-arch-ddd-example-shared-task-manager-util",
	"version": "0.0.1",
	"scripts": {
		"build": "run-p --continue-on-error --aggregate-output build:*",
		"build:tsup": "tsup",
		"build:tsc-declaration": "tsc -p tsconfig.build.json --emitDeclarationOnly",
		"check": "run-p --continue-on-error --aggregate-output check:*",
		"check:typescript": "tsc --noEmit",
		"clean": "rimraf ./dist *.tsbuildinfo"
	},
	"type": "module",
	"exports": {
		".": "./dist/index.js"
	},
	"devDependencies": {
		"@faker-js/faker": "^10.3.0",
		"@kxphotographer/layered-arch-ddd-example-shared-task-manager-config-base": "workspace:*",
		"@types/node": "^25.3.0",
		"npm-run-all": "^4.1.5",
		"rimraf": "^6.1.3",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"vite-tsconfig-paths": "^6.1.1"
	},
	"dependencies": {
		"@date-fns/tz": "^1.4.1",
		"date-fns": "^4.1.0",
		"valibot": "^1.2.0",
		"vitest": "^4.0.18"
	}
}
